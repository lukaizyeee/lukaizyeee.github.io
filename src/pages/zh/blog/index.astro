---
// src/pages/zh/blog/index.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import SectionRule from '../../../components/SectionRule.astro';
import PostList from '../../../components/PostList.astro';
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<BaseLayout locale="zh" title="博客 — 张子灏" description="关于 AI 系统、操作系统与工程实践的笔记。" altHref="/blog">
  <SectionRule no="02" title="博客" />
  <PostList posts={posts} locale="zh" />
</BaseLayout>
